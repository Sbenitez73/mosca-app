# ─────────────────────────────────────────────────────────────────────────────
# Mosca — secrets template
# ─────────────────────────────────────────────────────────────────────────────
# 1. Copy this file:  cp secrets.env.example secrets.env
# 2. Fill in your values below
# 3. Run:            bash scripts/setup_secrets.sh
#
# Where to get the Google values:
#   https://console.cloud.google.com/apis/credentials
#   → Create an OAuth 2.0 Client ID for "Web application" (server client ID)
#   → Create an OAuth 2.0 Client ID for "iOS" (iOS client ID)
# ─────────────────────────────────────────────────────────────────────────────

# OAuth Web/Server Client ID — used by GoogleSignIn's serverClientId
GOOGLE_SERVER_CLIENT_ID=your_web_client_id.apps.googleusercontent.com

# OAuth iOS Client ID — from Google Cloud Console → iOS credential
GOOGLE_IOS_CLIENT_ID=your_ios_client_id.apps.googleusercontent.com

# Reversed iOS Client ID (swap "com.googleusercontent.apps." prefix)
# e.g. if iOS client ID is 123456-abc.apps.googleusercontent.com
#      then reversed is com.googleusercontent.apps.123456-abc
GOOGLE_REVERSED_CLIENT_ID=com.googleusercontent.apps.your_ios_client_id

# iOS bundle identifier registered in Apple Developer Portal
BUNDLE_ID=com.yourcompany.mosca

# iOS App Group ID (must match Xcode → Signing & Capabilities → App Groups)
APP_GROUP_ID=group.com.yourcompany.mosca
